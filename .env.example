# ---- Host ports (change these if they conflict) ----
WEB_PORT=5174
API_PORT=4001
DB_PORT=5433

# ---- Database ----
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental
POSTGRES_DB=rental

# ---- Backend ----
# When running via docker compose the hostname is `db`; locally, it's `localhost`.
DATABASE_URL=postgres://rental:rental@db:5432/rental
JWT_SECRET=change-me-to-a-long-random-string
# CORS_ORIGIN must match the browser's origin (WEB_PORT on the host).
CORS_ORIGIN=http://localhost:5174
# PUBLIC_WEB_URL is where QR-code scan redirects land. Defaults to CORS_ORIGIN
# if unset; set this explicitly in production.
# PUBLIC_WEB_URL=https://ag-rental.vercel.app

# ---- Admin bootstrap ----
# The single admin account is auto-created on first API boot.
ADMIN_EMAIL=admin@ag-rental.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# ---- Default demo accounts (client + mechanic) ----
# Auto-created on first API boot so the app is immediately testable.
# Set either EMAIL var to an empty string to skip seeding that account.
DEFAULT_CLIENT_EMAIL=client@ag-rental.local
DEFAULT_CLIENT_PASSWORD=client123
DEFAULT_CLIENT_NAME=Demo Client

DEFAULT_MECHANIC_EMAIL=mechanic@ag-rental.local
DEFAULT_MECHANIC_PASSWORD=mechanic123
DEFAULT_MECHANIC_NAME=Demo Mechanic

# ---- Email verification (Resend) ----
# Create an account at https://resend.com and paste the API key here.
# Leave blank to run in dev mode: codes will be logged to the API container's
# console instead of being emailed.
RESEND_API_KEY=
# Sender identity. "onboarding@resend.dev" works out of the box without
# verifying a domain; for production use a verified domain like
# "AG Rental <noreply@agholding.us>".
RESEND_FROM=AG Rental <onboarding@resend.dev>

# ---- Phone verification (Twilio Verify) ----
# Create an account at https://twilio.com, then create a Verify Service
# (Console → Verify → Services). Leave any of these blank to run in dev
# mode: SMS is skipped and the code "123456" always works.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ---- Frontend ----
# VITE_API_URL is what the browser calls, so it uses the host API_PORT.
VITE_API_URL=http://localhost:4001
